{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ThreadEx",
  "version": "0.1.1",
  "identifier": "com.paulbouzian.threadex",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ThreadEx",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5M0I2NjM5ODE0NDBEMjEKUldRaERVU0JPV1k3U1dDdFV3bVh0Z1JEekZ1dHNYL3FGUEk0TnJiMjlhQmd3Q01pazNKRWNFWDIK",
      "endpoints": [
        "https://github.com/paul-bouzian/ThreadEx/releases/latest/download/latest.json"
      ]
    }
  }
}
