{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skein",
  "version": "0.1.8",
  "identifier": "com.paulbouzian.skein",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Skein",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDRjFDMDNERUQyRUY0ODUKUldTRjlDN3RQY0R4bkUyNDErdmEzcUhvMGlkVXlUbjZFZDUxcW9OTFJaSEZaVlBJOUcrZ2J5UVIK",
      "endpoints": [
        "https://github.com/paul-bouzian/Skein/releases/latest/download/latest.json"
      ]
    }
  }
}
